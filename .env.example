GOOGLE_API_KEY=your-google-api-key-here

# Rate Limiting
RATE_LIMIT=1/30seconds

# reCAPTCHA (set to true and add real keys to enable)
RECAPTCHA_ENABLED=false
RECAPTCHA_SECRET_KEY=your-secret-key-here

# CORS
CORS_ORIGINS=http://localhost:5173

# Frontend reCAPTCHA
VITE_RECAPTCHA_SITE_KEY=your-site-key-here

# Google Analytics 4 (frontend)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Quiz timer (seconds per question)
QUIZ_TIMER_SECONDS=6
VITE_QUIZ_TIMER_SECONDS=6

# Langfuse AI agent tracing (backend)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
